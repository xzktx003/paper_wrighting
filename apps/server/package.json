{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @agent-orchestrator/shared build && pnpm run dev:app",
    "dev:app": "tsx watch src/index.ts",
    "build": "pnpm --filter @agent-orchestrator/shared build && tsc -p tsconfig.json",
    "test": "tsx --test src/**/*.test.ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "@agent-orchestrator/shared": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.6.0",
    "node-pty": "1.2.0-beta.12",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ssh2": "^1.15.5",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
